# Google Cloud Firestore Configuration
FIRESTORE_PROJECT_ID=your-gcp-project
FIRESTORE_CREDENTIALS_PATH=path/to/firestore-credentials.json
FIRESTORE_COLLECTION_PREFIX=validoai_

# ArangoDB Configuration (Multi-Model)
ARANGODB_HOST=localhost
ARANGODB_PORT=8529
ARANGODB_DATABASE=ai_valido_online
ARANGODB_USER=root
ARANGODB_PASSWORD=password
ARANGODB_URL=http://${ARANGODB_USER}:${ARANGODB_PASSWORD}@${ARANGODB_HOST}:${ARANGODB_PORT}

# OrientDB Configuration (Multi-Model)
ORIENTDB_HOST=localhost
ORIENTDB_PORT=2480
ORIENTDB_DATABASE=ai_valido_online
ORIENTDB_USER=admin
ORIENTDB_PASSWORD=admin
ORIENTDB_URL=remote:${ORIENTDB_HOST}:${ORIENTDB_PORT}/${ORIENTDB_DATABASE}

# Microsoft SQL Server Configuration
MSSQL_HOST=localhost
MSSQL_PORT=1433
MSSQL_NAME=ai_valido_online
MSSQL_USER=sa
MSSQL_PASSWORD=your-mssql-password
MSSQL_URL=mssql+pyodbc://sa:your-mssql-password@localhost:1433/ai_valido_online?driver=ODBC+Driver+17+for+SQL+Server
MSSQL_SSL=false
MSSQL_TIMEOUT=30
MSSQL_POOL_SIZE=5
MSSQL_MAX_CONNECTIONS=20

# Supabase Configuration (PostgreSQL with Supabase extensions)
SUPABASE_HOST=db.supabase.co
SUPABASE_PORT=5432
SUPABASE_NAME=postgres
SUPABASE_USER=postgres
SUPABASE_PASSWORD=your-supabase-password
SUPABASE_URL=postgresql://postgres:your-supabase-password@db.supabase.co:5432/postgres
SUPABASE_SSL=true
SUPABASE_TIMEOUT=30
SUPABASE_POOL_SIZE=10
SUPABASE_MAX_CONNECTIONS=50

# Supabase API Configuration
SUPABASE_API_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
