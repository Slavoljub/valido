# =============================================================================
# AI MODEL OUTPUT CONFIGURATION
# =============================================================================
# Output Format Options
SUPPORTED_OUTPUT_FORMATS=json,xml,csv,excel,pdf,html,markdown,text,sql,python,javascript,typescript,php,ruby,go,java,csharp,swift,kotlin,rust

# Output Features
ENABLE_STREAMING_OUTPUT=true
ENABLE_CODE_HIGHLIGHTING=true
ENABLE_CHART_GENERATION=true
ENABLE_TABLE_FORMATTING=true
ENABLE_IMAGE_GENERATION=true
ENABLE_FILE_EXPORT=true

# Output Limitations
MAX_OUTPUT_LENGTH=10000
MAX_CHART_POINTS=1000
MAX_TABLE_ROWS=5000
MAX_IMAGE_SIZE=2048

# Export Configuration
EXPORT_TO_GOOGLE_SHEETS=false
EXPORT_TO_AIRTABLE=false
EXPORT_TO_NOTION=false
EXPORT_TO_SLACK=false
EXPORT_TO_EMAIL=false

# =============================================================================
# AI USAGE DISCLAIMER CONFIGURATION
# =============================================================================
# AI Disclaimer Settings
AI_DISCLAIMER_ENABLED=true
AI_DISCLAIMER_POSITION=top  # top, bottom, modal
AI_DISCLAIMER_TYPE=warning  # info, warning, danger

# Disclaimer Content
AI_DISCLAIMER_TITLE="⚠️ Important AI Usage Notice"
AI_DISCLAIMER_TEXT="This AI assistant provides information based on available data and general knowledge. The responses are for informational purposes only and should not be considered as professional financial, legal, or business advice. Always consult with qualified professionals for specific recommendations. AI responses may contain inaccuracies or may not reflect the most current information."

# Additional Disclaimer Options
SHOW_AI_CONFIDENCE_SCORES=true
ENABLE_SOURCE_CITATION=true
REQUIRE_USER_CONFIRMATION=false
LOG_AI_INTERACTIONS=true

# =============================================================================
# CHAT INTERFACE ENHANCEMENTS
# =============================================================================
# Chat UI Features
ENABLE_VOICE_INPUT=false
ENABLE_VOICE_OUTPUT=false
ENABLE_FILE_UPLOAD=true
ENABLE_IMAGE_UPLOAD=true
ENABLE_CODE_EDITOR=false
ENABLE_RICH_TEXT_EDITOR=false

# Chat Display Options
SHOW_MESSAGE_TIMESTAMPS=true
SHOW_USER_AVATARS=true
SHOW_TYPING_INDICATORS=true
ENABLE_MESSAGE_REACTIONS=false
ENABLE_MESSAGE_THREADS=false

# Chat Behavior
AUTO_SCROLL_TO_BOTTOM=true
ENABLE_MESSAGE_SEARCH=true
ENABLE_MESSAGE_FILTERING=true
PRESERVE_CHAT_HISTORY=true
CHAT_HISTORY_RETENTION_DAYS=30

# Chat Analytics
TRACK_CHAT_METRICS=true
ANALYZE_CHAT_SENTIMENT=false
GENERATE_CHAT_REPORTS=true
EXPORT_CHAT_DATA=false

# =============================================================================
# BACKUP & MAINTENANCE
# =============================================================================
BACKUP_ENABLED=true
BACKUP_PATH=data/sqlite/backups
BACKUP_RETENTION_DAYS=30
AUTO_BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 0 * * *  # Daily at midnight

# Database Maintenance
DB_MAINTENANCE_ENABLED=true
DB_CLEANUP_DAYS=90
DB_OPTIMIZATION_ENABLED=true
DB_HEALTH_CHECKS=true
DB_CONNECTION_POOL_MONITORING=true

# System Monitoring
ENABLE_SYSTEM_MONITORING=true
MONITOR_CPU_USAGE=true
MONITOR_MEMORY_USAGE=true
MONITOR_DISK_USAGE=true
MONITOR_NETWORK_USAGE=true
ALERT_THRESHOLDS_CPU=80
ALERT_THRESHOLDS_MEMORY=85
ALERT_THRESHOLDS_DISK=90

# Health Check Endpoints
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PATH=/health
HEALTH_CHECK_INTERVAL=30
EXPOSE_METRICS=false
METRICS_PATH=/metrics

HTTPS_REDIRECT=false       # When true, HTTP requests are 308-redirected to HTTPS
