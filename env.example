# =============================================================================
# VALIDOAI - CONSOLIDATED ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and update with your actual values

# ---------------------------------------------------------------------
# ValidoAI Feature Toggles (boolean strings: true/false)
# ---------------------------------------------------------------------
USE_WEBSOCKETS=true      # Enable Flask-SocketIO background support
USE_GRPC=false           # Start gRPC metrics server on port 50051
USE_PROMETHEUS=true      # Expose /metrics endpoint and run exporter task
METRICS_EXPORTER=true    # Start metrics updater background loop

# Prometheus / Grafana helpers
PROMETHEUS_SCRAPE_PORT=5000  # Port Prometheus should scrape (5000 or 5001)
GRPC_METRICS_PORT=50051

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=true
SECRET_KEY=your-super-secret-key-change-this-in-production
APP_NAME=AI Valido Online
APP_VERSION=1.0.0
APP_DESCRIPTION=AI-powered financial management platform for Serbian businesses
DEFAULT_LANGUAGE=sr
SUPPORTED_LANGUAGES=sr,en,sl,sk,hu,de,es,it,nl,fr,pt,pl,cs,ro,bg,hr,mk,bs,tr,ru,zh,ja,ko,ar,hi

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
# ASGI/Hypercorn Support - Production Ready Server
USE_ASGI=true
USE_HYPERCORN=true

# HTTP/HTTPS Support with Dual Port Configuration
HOST=0.0.0.0
HTTP_PORT=5000
HTTPS_PORT=5001
USE_HTTPS=true
SSL_ENABLED=true

# SSL Certificate Configuration (Current Working Certificates)
SSL_CERT_FILE=certs/localhost-cert.crt
SSL_KEY_FILE=certs/localhost-key.pem
SSL_CERT_PATH=certs/certificate.pem
SSL_KEY_PATH=certs/private.key

# HTTP/2 and HTTP/3 Support
HTTP2_ENABLED=true
HTTP2_PUSH_ENABLED=true

# Hypercorn Production Configuration
HYPERCORN_WORKERS=1
HYPERCORN_WORKER_CLASS=asyncio
HYPERCORN_MAX_REQUESTS=1000
HYPERCORN_TIMEOUT=30
HYPERCORN_KEEPALIVE=2
HYPERCORN_ACCESS_LOG=true
HYPERCORN_ERROR_LOG=true
HYPERCORN_LOG_LEVEL=info

# Debug Support for Development
HYPERCORN_DEBUG=true
HYPERCORN_RELOAD=false

# Server Settings (Legacy)
WORKERS=4
WORKER_CLASS=gunicorn.workers.sync.SyncWorker
WORKER_CONNECTIONS=1000
MAX_REQUESTS=1000
MAX_REQUESTS_JITTER=50
TIMEOUT=30
KEEPALIVE=2

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Database Type Selection
DATABASE_TYPE=sqlite  # Options: postgresql, mysql, sqlite, mongodb, redis, elasticsearch, cassandra, neo4j

# SQLite Database (Primary)
SQLITE_PATH=data/sqlite/app.db
SQLITE_URL=sqlite:///${SQLITE_PATH}

# PostgreSQL Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_NAME=ai_valido_online
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_NAME}

# Embeddings Database (Vector Storage)
EMBEDDINGS_DB_TYPE=postgresql
EMBEDDINGS_DB_HOST=localhost
EMBEDDINGS_DB_PORT=5432
EMBEDDINGS_DB_NAME=embeddings_ai_valido_online
EMBEDDINGS_DB_USER=postgres
EMBEDDINGS_DB_PASSWORD=postgres
EMBEDDINGS_DB_SSL=true
EMBEDDINGS_DB_URL=postgresql://${EMBEDDINGS_DB_USER}:${EMBEDDINGS_DB_PASSWORD}@${EMBEDDINGS_DB_HOST}:${EMBEDDINGS_DB_PORT}/${EMBEDDINGS_DB_NAME}

# MySQL Database
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_NAME=ai_valido_online
MYSQL_USER=root
MYSQL_PASSWORD=root
