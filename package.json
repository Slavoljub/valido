{
  "name": "validoai-frontend",
  "version": "1.0.0",
  "description": "ValidoAI Frontend with Modern Design System",
  "scripts": {
    "install-deps": "npm install",
    "build": "npm run build-css && npm run build-js",
    "build-css": "tailwindcss -i ./static/css/input.css -o ./static/css/output.css --watch",
    "build-css-prod": "tailwindcss -i ./static/css/input.css -o ./static/css/output.min.css --minify",
    "build-js": "npm run build-design && npm run build-components && npm run build-main && npm run build-app",
    "build-design": "esbuild ./static/js/design-system.js --minify --sourcemap --outfile=./static/dist/js/design-system.min.js",
    "build-components": "esbuild ./static/js/components.js --minify --sourcemap --outfile=./static/dist/js/components.min.js",
    "build-main": "esbuild ./static/js/main.js --minify --sourcemap --outfile=./static/dist/js/main.min.js",
    "build-app": "esbuild ./static/js/app.js --minify --sourcemap --bundle --outfile=./static/dist/js/app.min.js",
    "build-webpack": "webpack --mode=production --config webpack.config.js",
    "build-all": "npm run build-css-prod && npm run build-js",
    "dev": "concurrently \"npm run build-css\" \"npm run build-js\"",
    "clean": "rm -rf ./static/css/output.min.css ./static/js/*.min.js ./static/dist ./static/build",
    "minify": "npm run build-all && npm run build-webpack",
    "minify:advanced": "npm run minify && npm run optimize-images",
    "optimize-images": "imagemin ./static/images/* --out-dir=./static/dist/images --plugin=mozjpeg --plugin=pngquant --plugin=gifsicle --plugin=svgo",
    "compress": "gzip -9 -k ./static/dist/**/*.{js,css}",
    "analyze-size": "npm run build-all && npx bundlesize",
    "critical-css": "critical --base ./static/dist --src index.html --dest ./static/dist/css/critical.css --minify --extract",
    "predeploy": "npm run minify:advanced && npm run analyze-size",
    "analyze": "npm run build-all && npm run analyze-bundle",
    "analyze-bundle": "npx webpack-bundle-analyzer ./static/build/stats.json",
    "lint": "eslint ./static/js/*.js",
    "lint:fix": "eslint ./static/js/*.js --fix",
    "format": "prettier --write ./static/js/*.js ./static/css/*.css",
    "test": "jest",
    "start": "npm run build-all && python app.py"
  },
  "devDependencies": {
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.16",
    "autoprefixer": "^10.4.16",
    "compression-webpack-plugin": "^10.0.0",
    "concurrently": "^8.2.2",
    "copy-webpack-plugin": "^11.0.0",
    "css-minimizer-webpack-plugin": "^5.0.1",
    "cssnano": "^6.0.1",
    "esbuild": "^0.19.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "mini-css-extract-plugin": "^2.7.6",
    "postcss": "^8.4.32",
    "postcss-cli": "^10.1.0",
    "prettier": "^3.1.0",
    "tailwindcss": "^3.4.0",
    "terser-webpack-plugin": "^5.3.9",
    "webpack": "^5.89.0",
    "webpack-bundle-analyzer": "^4.10.1",
    "webpack-cli": "^5.1.4",
    "workbox-webpack-plugin": "^7.0.0"
  },
  "dependencies": {
    "alpinejs": "^3.13.3",
    "apexcharts": "^3.35.3",
    "chart.js": "^4.4.0",
    "feather-icons": "^4.29.0",
    "flag-icons": "^7.5.0",
    "flowbite": "^1.8.1",
    "lucide": "^0.294.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "main": "postcss.config.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs"
}
