[run]
source = src
omit =
    */tests/*
    */test_*
    */__pycache__/*
    */venv/*
    */node_modules/*
    */static/*
    */templates/*
    */docs/*

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    if self.debug:
    if settings.DEBUG
    raise AssertionError
    raise NotImplementedError
    if 0:
    if __name__ .__main__.:
    class .*\bProtocol\):
    @(abc\.)?abstractmethod

[html]
directory = htmlcov

[xml]
output = coverage.xml

[paths]
source =
    src/
    */site-packages/
