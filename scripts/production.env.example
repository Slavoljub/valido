# ValidoAI Production Environment Configuration
# Copy this file to .env and update values for your environment

# Flask Configuration
FLASK_ENV=production
SECRET_KEY=change-this-to-a-secure-random-key
DEBUG_MODE=false

# Server Configuration
SERVER_TYPE=hypercorn  # Options: hypercorn, uvicorn, gunicorn
HOST=0.0.0.0
PORT=5000
HTTP_PORT=5000
HTTPS_PORT=5001
WORKERS=4

# SSL Configuration (for Hypercorn)
SSL_ENABLED=false
SSL_CERT_PATH=certs/certificate.pem
SSL_KEY_PATH=certs/private.key

# Database Configuration
DATABASE=data/sqlite/app.db
DB_ENGINE=sqlite  # Options: sqlite, postgresql, mysql, mongodb

# PostgreSQL (if using PostgreSQL)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=validoai
POSTGRES_USER=validoai
POSTGRES_PASSWORD=change-this-password

# MySQL (if using MySQL)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=validoai
MYSQL_USER=validoai
MYSQL_PASSWORD=change-this-password

# MongoDB (if using MongoDB)
MONGODB_URI=mongodb://localhost:27017/validoai

# Redis Configuration (for caching)
REDIS_URL=redis://localhost:6379/0

# AI Configuration
AI_MODEL_CACHE=cache/models
HUGGINGFACE_CACHE=cache/huggingface

# GPU Configuration
GPU_ENABLED=false
CUDA_VISIBLE_DEVICES=0

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
ERROR_LOG=logs/errors.log

# Security
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
REMEMBER_COOKIE_SECURE=true
REMEMBER_COOKIE_HTTPONLY=true

# Email Configuration (optional)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# File Upload
MAX_CONTENT_LENGTH=16777216  # 16MB
UPLOAD_FOLDER=uploads

# API Configuration
API_RATE_LIMIT=100  # requests per minute

# Startup Checks
STARTUP_CHECKS_ENABLED=true
DATABASE_CONNECTION_CHECKS=true
QUESTION_MANAGER_INIT=true
AI_SYSTEM_INIT=true
VERBOSE_STARTUP_LOGS=false

# Translation
BABEL_DEFAULT_LOCALE=en
BABEL_DEFAULT_TIMEZONE=Europe/Belgrade
