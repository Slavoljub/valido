#!/usr/bin/env bash

# ValidoAI Unified Cross-Platform Docker Management Script
# Supports Linux, macOS, and Windows (PowerShell, WSL, Git Bash)
# Usage: ./docker-run <command> [options]

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Function to print colored output
print_status() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

print_header() {
    echo -e "${BLUE}================================${NC}"
    echo -e "${BLUE}$1${NC}"
    echo -e "${BLUE}================================${NC}"
}

# Function to show progress bar
show_progress() {
    local current=$1
    local total=$2
    local width=50
    local percentage=$((current * 100 / total))
    local filled=$((width * current / total))
    local empty=$((width - filled))
    
    # Create progress bar string
    local bar=""
    for ((i=0; i<filled; i++)); do
        bar="${bar}█"
    done
    for ((i=0; i<empty; i++)); do
        bar="${bar}░"
    done
    
    # Print progress bar
    printf "\r${BLUE}[%3d%%]${NC} [%s] %d/%d" "$percentage" "$bar" "$current" "$total"
    
    # Add newline if complete
    if [ "$current" -eq "$total" ]; then
        echo ""
    fi
}

# Function to show spinner
show_spinner() {
    local pid=$1
    local delay=0.1
    local spinstr='|/-\'
    
    while [ "$(ps a | awk '{print $1}' | grep $pid)" ]; do
        local temp=${spinstr#?}
        printf "\r${BLUE}[%c]${NC} Processing..." "$spinstr"
        local spinstr=$temp${spinstr%"$temp"}
        sleep $delay
    done
    printf "\r${GREEN}[✓]${NC} Complete!    \n"
}

# Function to show download progress
show_download_progress() {
    local current=$1
    local total=$2
    local item_name=$3
    
    show_progress "$current" "$total"
    if [ -n "$item_name" ]; then
        printf " ${YELLOW}%s${NC}" "$item_name"
    fi
}

# Function to detect OS and shell
detect_environment() {
    local os=""
    local shell_type=""
    
    # Detect OS
    case "$(uname -s)" in
        Linux*)     os="linux";;
        Darwin*)    os="macos";;
        CYGWIN*|MINGW*|MSYS*) os="windows";;
        *)          os="unknown";;
    esac
    
    # Detect shell
    if [ -n "$ZSH_VERSION" ]; then
        shell_type="zsh"
    elif [ -n "$BASH_VERSION" ]; then
        shell_type="bash"
    elif [ -n "$POWERSHELL_VERSION" ] || [ -n "$PSVersionTable" ]; then
        shell_type="powershell"
    else
        shell_type="unknown"
    fi
    
    echo "$os:$shell_type"
}

# Function to check if Docker is running
check_docker() {
    if ! docker info >/dev/null 2>&1; then
        print_error "Docker is not running or not accessible"
        print_status "Please start Docker Desktop or Docker daemon"
        exit 1
    fi
    print_status "Docker is running"
}

# Function to check if docker-compose is available
check_docker_compose() {
    if ! command -v docker-compose >/dev/null 2>&1; then
        print_error "docker-compose is not installed or not in PATH"
        exit 1
    fi
    print_status "docker-compose is available"
}

# Function to create necessary directories
create_directories() {
    local env_info=$(detect_environment)
    local os=$(echo "$env_info" | cut -d: -f1)
    
    print_status "Creating necessary directories for $os..."
    
    # Create individual database directories
    mkdir -p database/postgresql 2>/dev/null || true
    mkdir -p database/mysql 2>/dev/null || true
    mkdir -p database/redis 2>/dev/null || true
    mkdir -p database/mongodb 2>/dev/null || true
    mkdir -p database/cassandra 2>/dev/null || true
    mkdir -p database/couchdb 2>/dev/null || true
    mkdir -p database/couchbase 2>/dev/null || true
    mkdir -p database/influxdb 2>/dev/null || true
    mkdir -p database/clickhouse 2>/dev/null || true
    mkdir -p database/neo4j 2>/dev/null || true
    mkdir -p database/arangodb 2>/dev/null || true
    mkdir -p database/orientdb 2>/dev/null || true
    mkdir -p database/elasticsearch 2>/dev/null || true
    mkdir -p database/weaviate 2>/dev/null || true
    mkdir -p database/qdrant 2>/dev/null || true
    mkdir -p database/chromadb 2>/dev/null || true
    mkdir -p database/milvus 2>/dev/null || true
    mkdir -p database/dynamodb 2>/dev/null || true
    mkdir -p database/cosmosdb 2>/dev/null || true
    mkdir -p database/firestore 2>/dev/null || true
    mkdir -p database/pgadmin 2>/dev/null || true
    mkdir -p database/mssql 2>/dev/null || true
    
    # Create shared data directory
