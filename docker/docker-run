# Function to download all Docker images
download_all_images() {
    print_header "Downloading All Docker Images"
    
    print_status "This will download all images used in the Docker Compose setup..."
    print_status "This may take several minutes depending on your internet connection."
    echo ""
    
    # List of all images to download
    local images=(
        "postgres:17-alpine"
        "mysql:8.4"
        "mcr.microsoft.com/mssql/server:2022-latest"
        "mongo:8.1"
        "redis/redis-stack:latest"
        "cassandra:5.1"
        "couchdb:3.4"
        "couchbase/server:7.7"
        "influxdb:2.8"
        "clickhouse/clickhouse-server:24.8"
        "neo4j:5.18"
        "arangodb:3.13"
        "orientdb:3.3"
        "docker.elastic.co/elasticsearch/elasticsearch:8.12.0"
        "semitechnologies/weaviate:1.24.0"
        "qdrant/qdrant:latest"
        "chromadb/chroma:latest"
        "milvusdb/milvus:v2.4.0"
        "amazon/dynamodb-local:latest"
        "mcr.microsoft.com/cosmosdb/linux/azure-cosmos-emulator:latest"
        "gcr.io/google.com/cloudsdktool/cloud-sdk:latest"
        "adminer:latest"
        "phpmyadmin/phpmyadmin:latest"
        "mongo-express:latest"
        "rediscommander/redis-commander:latest"
        "cars10/elasticvue:latest"
        "dpage/pgadmin4:latest"
        "nginx:alpine"
    )
    
    local total_images=${#images[@]}
    local current=0
    local successful=0
    local failed=0
    
    print_status "Starting download of $total_images images..."
    echo ""
    
    for image in "${images[@]}"; do
        current=$((current + 1))
        
        # Show progress bar with image name
        show_download_progress "$current" "$total_images" "$image"
        
        # Download image with progress
        if docker pull "$image" > /dev/null 2>&1; then
            successful=$((successful + 1))
            printf "\r${GREEN}[✓]${NC} Successfully downloaded: ${YELLOW}%s${NC}\n" "$image"
        else
            failed=$((failed + 1))
            printf "\r${RED}[✗]${NC} Failed to download: ${YELLOW}%s${NC} (will be downloaded when needed)\n" "$image"
        fi
    done
    
    echo ""
    print_header "Download Summary"
    print_status "Total images: $total_images"
    print_status "Successfully downloaded: $successful"
    if [ $failed -gt 0 ]; then
        print_warning "Failed downloads: $failed (will be downloaded when needed)"
    fi
    print_status "Image download process completed!"
}

