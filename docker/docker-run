# Function to set up environment variables
setup_environment() {
    local env_info=$(detect_environment)
    local os=$(echo "$env_info" | cut -d: -f1)
    
    print_status "Setting up environment for $os..."
    
    # Export common environment variables
    export DOCKER_COMPOSE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    export PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
    
    # OS-specific settings
    case $os in
        "windows")
            export COMPOSE_CONVERT_WINDOWS_PATHS=1
            ;;
        "macos")
            export DOCKER_DEFAULT_PLATFORM=linux/amd64
            ;;
        "linux")
            export DOCKER_DEFAULT_PLATFORM=linux/amd64
            ;;
    esac
    
    print_status "Environment setup complete"
}

# Function to run tests
run_tests() {
    print_header "Running Docker Tests"
    
    local test_dir="tests"
    
    if [ ! -d "$test_dir" ]; then
        print_warning "Test directory not found: $test_dir"
        print_status "Creating test directory and basic tests..."
        mkdir -p "$test_dir"
        create_basic_tests
        return 0
    fi
    
    # Run all test scripts
    for test_file in "$test_dir"/*.sh "$test_dir"/*.ps1; do
        if [ -f "$test_file" ] && [ -x "$test_file" ]; then
            print_status "Running test: $(basename "$test_file")"
            "$test_file"
        fi
    done
    
    print_status "✓ All tests completed"
}

