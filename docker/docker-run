# Main function
main() {
    local command="$1"
    local profile="$2"
    local service="$3"
    local additional_args="$4"
    
    # Check prerequisites
    check_docker
    check_docker_compose
    
    # Setup environment
    setup_environment
    
    # Create directories if they don't exist
    create_directories
    
    case "$command" in
        "up")
            if [ -n "$profile" ]; then
                print_header "Starting Services with Profile: $profile"
                print_status "Building and starting services..."
                
                # Show progress for service startup
                cd "$DOCKER_COMPOSE_DIR"
                
                # Build services first
                print_status "Building services..."
                docker-compose --profile "$profile" build > /dev/null 2>&1
                
                # Start services
                print_status "Starting services..."
                docker-compose --profile "$profile" up -d
                
                print_status "✓ Services started successfully"
                print_status "Use '$0 ps' to check service status"
                print_status "Use '$0 logs' to view service logs"
            else
                print_error "Profile not specified"
                print_status "Available profiles: app, databases, management, nginx"
                print_status "Usage: $0 up <profile>"
                return 1
            fi
            ;;
        "down")
            print_header "Stopping All Services"
            cd "$DOCKER_COMPOSE_DIR" && docker-compose down
            print_status "All services stopped"
            ;;
        "build")
            print_header "Building Services"
            print_status "Building all services..."
            cd "$DOCKER_COMPOSE_DIR"
            
            # Build with progress
            docker-compose build
            
            print_status "✓ Build completed successfully"
            ;;
        "restart")
            if [ -n "$service" ]; then
                print_status "Restarting service: $service"
                cd "$DOCKER_COMPOSE_DIR" && docker-compose restart "$service"
            else
                print_status "Restarting all services"
                cd "$DOCKER_COMPOSE_DIR" && docker-compose restart
            fi
            ;;
        "stop")
            print_status "Stopping all services"
            cd "$DOCKER_COMPOSE_DIR" && docker-compose stop
            ;;
        "start")
            print_status "Starting all services"
            cd "$DOCKER_COMPOSE_DIR" && docker-compose start
            ;;
        "start-app")
            print_header "Starting Application Container"
            print_status "Starting dependencies first..."
            cd "$DOCKER_COMPOSE_DIR"
            docker-compose up -d postgresql redis
            print_status "Waiting for dependencies to be ready..."
            sleep 10
            print_status "Starting the py_ai_valido application container..."
            docker-compose --profile manual up -d py_ai_valido
            print_status "✓ Application container started successfully"
            print_status "Container: py_ai_valido"
            print_status "Access at: http://localhost:5000"
            ;;
        "stop-app")
            print_status "Stopping the py_ai_valido application container..."
            cd "$DOCKER_COMPOSE_DIR" && docker-compose stop py_ai_valido
            print_status "✓ Application container stopped"
            ;;
        "logs")
            show_logs "$service"
            ;;
        "ps")
            show_status
            ;;
        "exec")
            exec_container "$service" "$additional_args"
            ;;
        "test")
            run_tests
            ;;
        "tdd")
            run_tdd_tests
            ;;
        "backup")
            backup_databases
            ;;
        "restore")
            restore_databases "$service"
            ;;
        "clean")
            clean_docker
            ;;
        "init")
            initialize_environment
            ;;
        *)
            print_header "ValidoAI Unified Docker Management"
            echo "Usage: $0 <command> [options]"
            echo ""
            echo "Commands:"
            echo "  up <profile>           - Start services with profile (app|databases|management|nginx|manual|development|individual services)"
            echo "  down                   - Stop all services"
            echo "  build                  - Build all services"
            echo "  restart [service]      - Restart all services or specific service"
            echo "  stop                   - Stop all services"
            echo "  start                  - Start all services"
            echo "  start-app              - Start the py_ai_valido application container"
            echo "  stop-app               - Stop the py_ai_valido application container"
            echo "  logs [service]         - Show logs for all services or specific service"
            echo "  ps                     - Show status of all services"
            echo "  exec <service> [cmd]   - Execute command in container (default: bash)"
            echo "  test                   - Run all tests"
            echo "  tdd                    - Run TDD tests"
            echo "  backup                 - Create database backup"
            echo "  restore <backup_path>  - Restore database from backup"
            echo "  clean                  - Clean up Docker resources"
            echo "  init                   - Initialize Docker environment"
            echo ""
            echo "Profiles:"
            echo "  development            - Start all services for development"
            echo "  databases              - Start all databases with admin tools"
            echo "  management             - Start only admin tools"
            echo "  app                    - Start application with dependencies"
            echo "  manual                 - Start application container only"
            echo "  nginx                  - Start reverse proxy"
            echo "  Individual services:   - postgresql, mysql, redis, mongodb, etc."
            echo ""
            echo "Examples:"
            echo "  $0 up development       # Start all services for development"
            echo "  $0 up databases         # Start all databases with admin tools"
            echo "  $0 up postgresql        # Start only PostgreSQL"
            echo "  $0 up mysql redis       # Start MySQL and Redis"
            echo "  $0 start-app           # Start application container"
            echo "  $0 logs postgresql     # View PostgreSQL logs"
            echo "  $0 exec postgresql psql -U valido # Connect to PostgreSQL"
            echo "  $0 backup              # Create backup"
            echo "  $0 test                # Run tests"
            ;;
    esac
}

# Run main function with all arguments
main "$@"
