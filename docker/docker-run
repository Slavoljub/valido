# Function to backup databases
backup_databases() {
    print_header "Creating Database Backup"
    
    local timestamp=$(date +%Y%m%d_%H%M%S)
    local backup_dir="data/backups/$timestamp"
    
    mkdir -p "$backup_dir"
    
    print_status "Stopping services for backup..."
    cd "$DOCKER_COMPOSE_DIR" && docker-compose stop
    
    print_status "Creating backup at: $backup_dir"
    
    # Show progress for backup operations
    print_status "Copying database files..."
    
    # Copy all database data with progress
    if [ -d "data/shared_databases" ]; then
        print_status "Copying shared databases..."
        cp -r data/shared_databases/* "$backup_dir/" 2>/dev/null || true
    fi
    
    # Copy database directories with progress
    if [ -d "database" ]; then
        print_status "Copying individual database directories..."
        cp -r database "$backup_dir/" 2>/dev/null || true
    fi
    
    print_status "✓ Backup completed successfully at: $backup_dir"
    
    print_status "Restarting services..."
    cd "$DOCKER_COMPOSE_DIR" && docker-compose start
}

# Function to restore databases
restore_databases() {
    local backup_path="$1"
    
    if [ -z "$backup_path" ]; then
        print_error "Backup path not specified"
        print_status "Usage: $0 restore <backup_path>"
        return 1
    fi
    
    if [ ! -d "$backup_path" ]; then
        print_error "Backup directory not found: $backup_path"
        return 1
    fi
    
    print_header "Restoring Database Backup"
    
    print_status "Stopping services for restore..."
    cd "$DOCKER_COMPOSE_DIR" && docker-compose stop
    
    print_status "Restoring from: $backup_path"
    
    # Restore shared data
    if [ -d "$backup_path/shared_databases" ]; then
        rm -rf data/shared_databases/*
        cp -r "$backup_path/shared_databases"/* data/shared_databases/
    fi
    
    # Restore shared database directory
    if [ -d "$backup_path/database" ]; then
        rm -rf docker/database
        cp -r "$backup_path/database" docker/
    fi
    
    print_status "Restore completed successfully"
    
    print_status "Restarting services..."
    cd "$DOCKER_COMPOSE_DIR" && docker-compose start
}

# Function to clean up Docker resources
clean_docker() {
    print_header "Cleaning Docker Resources"
    
    print_status "Step 1/5: Stopping all services..."
    cd "$DOCKER_COMPOSE_DIR" && docker-compose down -v
    
    print_status "Step 2/5: Removing unused containers..."
    docker container prune -f
    
    print_status "Step 3/5: Removing unused images..."
    docker image prune -f
    
    print_status "Step 4/5: Removing unused volumes..."
    docker volume prune -f
    
    print_status "Step 5/5: Removing unused networks..."
    docker network prune -f
    
    print_status "✓ Cleanup completed successfully"
}

# Function to show status
show_status() {
    print_header "Docker Services Status"
    
    cd "$DOCKER_COMPOSE_DIR" && docker-compose ps
    
    print_header "System Information"
    local env_info=$(detect_environment)
    local os=$(echo "$env_info" | cut -d: -f1)
    local shell_type=$(echo "$env_info" | cut -d: -f2)
    echo "OS: $os"
    echo "Shell: $shell_type"
    echo "Docker Version: $(docker --version)"
    echo "Docker Compose Version: $(docker-compose --version)"
    echo "Project Root: $PROJECT_ROOT"
    echo "Docker Compose Dir: $DOCKER_COMPOSE_DIR"
}

# Function to show logs
show_logs() {
    local service="$1"
    
    if [ -n "$service" ]; then
        print_status "Showing logs for service: $service"
        cd "$DOCKER_COMPOSE_DIR" && docker-compose logs -f "$service"
    else
        print_status "Showing all logs"
        cd "$DOCKER_COMPOSE_DIR" && docker-compose logs -f
    fi
}

# Function to execute command in container
exec_container() {
    local service="$1"
    local command="$2"
    
    if [ -z "$service" ]; then
        print_error "Service name not specified"
        print_status "Usage: $0 exec <service> [command]"
        return 1
    fi
    
    if [ -z "$command" ]; then
        command="bash"
    fi
    
    print_status "Executing '$command' in service: $service"
    cd "$DOCKER_COMPOSE_DIR" && docker-compose exec "$service" "$command"
}

